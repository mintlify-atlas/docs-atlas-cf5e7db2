  "keyFeatures": [
    "Secure TLS-only IMAP connections with certificate verification",
    "10 MCP tools for comprehensive email operations",
    "Cursor-based pagination for efficient large mailbox navigation",
    "Multi-account support via environment variables",
    "Write operations gated behind explicit security flag",
    "Message parsing with HTML sanitization",
    "PDF text extraction from attachments",
    "Structured error handling with actionable diagnostics"
  ],
  "publicApiSurface": [
    "imap_list_accounts - List configured IMAP accounts",
    "imap_verify_account - Verify account connectivity and capabilities",
    "imap_list_mailboxes - List visible mailboxes/folders",
    "imap_search_messages - Search messages with cursor pagination",
    "imap_get_message - Get parsed message details",
    "imap_get_message_raw - Get bounded RFC822 source",
    "imap_update_message_flags - Add or remove IMAP flags",
    "imap_copy_message - Copy message to mailbox",
    "imap_move_message - Move message to mailbox",
    "imap_delete_message - Delete message from mailbox"
  ]
